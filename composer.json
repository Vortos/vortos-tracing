{
    "name": "vortos/vortos-tracing",
    "description": "Vortos tracing \u2014 OpenTelemetry distributed tracing integration",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Vortos\\Tracing\\": ""
        }
    },
    "require": {
        "php": ">=8.2",
        "vortos/vortos-foundation": "^1.0",
        "symfony/service-contracts": "^3.0"
    },
    "suggest": {
        "open-telemetry/api": "Required for OpenTelemetryTracer",
        "open-telemetry/sdk": "Required for OpenTelemetry SDK instrumentation",
        "open-telemetry/exporter-otlp": "Required for OTLP trace export"
    },
    "extra": {
        "vortos": {
            "package": "Vortos\\Tracing\\DependencyInjection\\TracingPackage",
            "order": 50
        }
    }
}
